{
  "name": "ebuilder-construct-agent-mcp",
  "version": "1.0.0",
  "description": "Domain-orchestration MCP server for Unity Construct (e-Builder) APIs",
  "private": true,
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc && shx chmod 755 build/index.js build/http.js",
    "start": "node build/index.js",
    "start:http": "node build/http.js",
    "typecheck": "tsc --noEmit",
    "smoke-test": "tsx src/smoke-test.ts",
    "prestart": "npm run build",
    "prestart:http": "npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.2",
    "shx": "^0.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
