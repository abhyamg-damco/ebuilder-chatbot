# e-Builder API base URL (US2 tenant)
EBUILDER_BASE_URL=https://api2-us2.e-builder.net

# Password-grant credentials (required unless EBUILDER_ACCESS_TOKEN is set)
EBUILDER_USERNAME=
EBUILDER_PASSWORD=

# Optional: skip Authenticate call and use a pre-issued bearer token
# EBUILDER_ACCESS_TOKEN=

# HTTP server (start:http)
PORT=8080
# Optional: require Authorization: Bearer <key> on /mcp requests
# MCP_API_KEY=

# --- Chatbot registration (/settings/mcp/new) ---
# Local stdio:
#   transport: stdio
#   command: node
#   args: ["/absolute/path/to/ebuilder-agent-mcp/build/index.js"]
#   env: { EBUILDER_USERNAME, EBUILDER_PASSWORD, EBUILDER_BASE_URL }
#
# Remote HTTP:
#   transport: http
#   url: https://<host>:8080/mcp
#   headers: { "Authorization": "Bearer ${MCP_API_KEY}" }  # if MCP_API_KEY set
#   env: { EBUILDER_USERNAME, EBUILDER_PASSWORD, MCP_API_KEY }
